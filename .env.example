PORT=3000
# MongoDB
MONGO_URI=mongodb://localhost:27017/background_jobs

# AWS — real credentials from IAM
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_LAMBDA_ARN=
AWS_SCHEDULER_ROLE_ARN=
# EventBridge — must be a bus that exists in ap-south-1 on your account
EVENTBRIDGE_BUS_NAME=default
EVENTBRIDGE_SOURCE=app.background-jobs

# Security — Lambda attaches HMAC of request body as x-job-signature header
LAMBDA_WEBHOOK_SECRET=secret

# EventBridge Scheduler (only needed for trigger({ delayMs }) )
# Lambda ARN that Scheduler calls — same Lambda that forwards to your server
SCHEDULER_LAMBDA_ARN=
# IAM role that Scheduler uses to invoke the Lambda
SCHEDULER_ROLE_ARN=
# Optional: schedule group name (default: 'default')
SCHEDULER_GROUP_NAME=default

RESEND_API_KEY=
MAIL_FROM=delivered@resend.dev

